{
  "name": "interpreter",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "parcel build --cache-dir node_modules/.cache/parcel",
    "check": "tsc --build",
    "lint": "eslint --ext ts,tsx --fix src",
    "start": "parcel serve --cache-dir node_modules/.cache/parcel --dist-dir lib/ui --target ui",
    "test": "vitest",
    "watch": "parcel watch --cache-dir node_modules/.cache/parcel"
  },
  "dependencies": {
    "@blueprintjs/core": "4.12.0",
    "@codemirror/lang-javascript": "6.1.1",
    "@codemirror/lang-json": "6.0.1",
    "@hpcc-js/wasm": "2.2.0",
    "@parcel/transformer-inline-string": "2.8.3",
    "@types/node": "18.11.10",
    "@types/react": "18.0.25",
    "@types/react-dom": "18.0.9",
    "@types/react-svg-pan-zoom": "3.3.5",
    "@uiw/react-codemirror": "4.15.1",
    "@vitest/web-worker": "0.28.4",
    "buffer": "5.7.1",
    "chevrotain": "10.4.2",
    "commander": "9.4.1",
    "eslint-config-vazco": "7.1.0",
    "normalize.css": "8.0.1",
    "p-limit": "3.1.0",
    "parcel": "2.8.3",
    "process": "0.11.10",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-svg-pan-zoom": "3.11.0",
    "tslib": "2.4.1",
    "typescript": "4.9.3",
    "util": "0.12.5",
    "vitest": "0.28.4",
    "web-worker": "1.2.0"
  },
  "targets": {
    "cli": {
      "context": "node",
      "distDir": "lib/cli",
      "engines": {
        "node": ">= 18.13.0"
      },
      "optimize": false,
      "source": "src/cli/index.ts"
    },
    "ui": {
      "context": "browser",
      "distDir": "lib/ui",
      "engines": {
        "browsers": "> 1% and not dead"
      },
      "publicUrl": ".",
      "source": "src/ui/index.html",
      "sourceMap": false
    }
  }
}
