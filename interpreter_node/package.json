{
  "name": "interpreter",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "parcel build --cache-dir node_modules/.cache/parcel --no-scope-hoist",
    "check": "tsc --build",
    "lint": "eslint --ext ts,tsx --fix src",
    "postinstall": "monaco-treemending",
    "start": "parcel serve --cache-dir node_modules/.cache/parcel --dist-dir lib/ui --target ui",
    "watch": "parcel watch --cache-dir node_modules/.cache/parcel"
  },
  "dependencies": {
    "@blueprintjs/core": "5.16.6",
    "@codingame/monaco-vscode-files-service-override": "1.83.5",
    "@hpcc-js/wasm-graphviz": "1.7.0",
    "@parcel/transformer-inline-string": "2.13.3",
    "@types/lodash": "4.17.15",
    "@types/node": "22.13.4",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@types/react-svg-pan-zoom": "3.3.9",
    "@types/vscode": "1.83.2",
    "buffer": "6.0.3",
    "eslint-config-vazco": "7.4.0",
    "fflate": "0.8.2",
    "json-rpc-2.0": "1.7.0",
    "lodash": "4.17.21",
    "monaco-editor": "0.44.0",
    "normalize.css": "8.0.1",
    "p-limit": "6.2.0",
    "parcel": "2.13.3",
    "path-browserify": "1.0.1",
    "process": "0.11.10",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-svg-pan-zoom": "3.13.1",
    "svgo": "3.3.2",
    "tslib": "2.8.1",
    "typescript": "5.7.3",
    "util": "0.12.5",
    "vscode": "npm:@codingame/monaco-vscode-api@1.83.5",
    "vscode-jsonrpc": "8.2.1",
    "vscode-languageserver-protocol": "3.17.5",
    "web-worker": "1.5.0"
  },
  "overrides": {
    "vscode": "$vscode"
  },
  "resolutions": {
    "vscode": "npm:@codingame/monaco-vscode-api@1.83.5"
  },
  "targets": {
    "ui": {
      "context": "browser",
      "distDir": "lib/ui",
      "engines": {
        "browsers": "Chrome >= 118, Safari >= 17"
      },
      "publicUrl": ".",
      "source": "src/ui/index.html",
      "sourceMap": false
    }
  }
}
