{
  "name": "interpreter",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "lint": "eslint --ext ts src",
    "test": "jest",
    "ui:build": "parcel build --cache-dir node_modules/.cache/parcel --dist-dir lib/ui src/ui/index.html --no-source-maps --public-url .",
    "ui:start": "parcel serve --cache-dir node_modules/.cache/parcel --dist-dir lib/ui src/ui/index.html"
  },
  "dependencies": {
    "@blueprintjs/core": "4.12.0",
    "@codemirror/lang-javascript": "6.1.1",
    "@codemirror/lang-json": "6.0.1",
    "@hpcc-js/wasm": "2.2.0",
    "@parcel/transformer-inline-string": "2.8.0",
    "@types/jest": "29.2.3",
    "@types/node": "18.11.10",
    "@types/react": "18.0.25",
    "@types/react-dom": "18.0.9",
    "@types/react-svg-pan-zoom": "3.3.5",
    "@uiw/react-codemirror": "4.15.1",
    "chevrotain": "10.4.2",
    "commander": "9.4.1",
    "eslint-config-vazco": "7.1.0",
    "jest": "29.3.1",
    "normalize.css": "8.0.1",
    "parcel": "2.8.0",
    "process": "0.11.10",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-svg-pan-zoom": "3.11.0",
    "ts-jest": "29.0.3",
    "ts-node": "10.9.1",
    "tslib": "2.4.1",
    "typescript": "4.9.3",
    "util": "0.12.5"
  }
}
