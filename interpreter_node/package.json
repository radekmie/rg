{
  "name": "interpreter",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "lint": "eslint --ext ts src",
    "ui:build": "parcel build --cache-dir node_modules/.cache/parcel --dist-dir lib/ui src/ui/index.html --no-source-maps",
    "ui:start": "parcel serve --cache-dir node_modules/.cache/parcel --dist-dir lib/ui src/ui/index.html"
  },
  "dependencies": {
    "@blueprintjs/core": "4.3.1",
    "@codemirror/lang-javascript": "0.20.0",
    "@codemirror/lang-json": "0.20.0",
    "@hpcc-js/wasm": "1.14.1",
    "@parcel/transformer-inline-string": "2.5.0",
    "@types/node": "17.0.33",
    "@types/react": "18.0.9",
    "@types/react-dom": "18.0.4",
    "@uiw/react-codemirror": "4.7.0",
    "chevrotain": "10.1.2",
    "eslint-config-vazco": "6.2.0",
    "normalize.css": "8.0.1",
    "parcel": "2.5.0",
    "process": "0.11.10",
    "react": "18.1.0",
    "react-dom": "18.1.0",
    "tslib": "2.4.0",
    "typescript": "4.6.4",
    "util": "0.12.4"
  }
}
