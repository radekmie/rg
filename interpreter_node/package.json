{
  "name": "interpreter",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "lint": "eslint --ext ts src",
    "test": "jest",
    "ui:build": "parcel build --cache-dir node_modules/.cache/parcel --dist-dir lib/ui src/ui/index.html --no-source-maps --public-url .",
    "ui:start": "parcel serve --cache-dir node_modules/.cache/parcel --dist-dir lib/ui src/ui/index.html"
  },
  "dependencies": {
    "@blueprintjs/core": "4.5.1",
    "@codemirror/lang-javascript": "6.0.1",
    "@codemirror/lang-json": "6.0.0",
    "@hpcc-js/wasm": "2.1.0",
    "@parcel/transformer-inline-string": "2.6.2",
    "@types/jest": "28.1.3",
    "@types/node": "18.0.0",
    "@types/react": "18.0.14",
    "@types/react-dom": "18.0.5",
    "@types/react-svg-pan-zoom": "3.3.5",
    "@uiw/react-codemirror": "4.9.4",
    "chevrotain": "10.1.2",
    "commander": "9.3.0",
    "eslint-config-vazco": "7.0.0",
    "jest": "28.1.2",
    "normalize.css": "8.0.1",
    "parcel": "2.6.2",
    "process": "0.11.10",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-svg-pan-zoom": "3.11.0",
    "ts-jest": "28.0.5",
    "tslib": "2.4.0",
    "typescript": "4.7.4",
    "util": "0.12.4"
  }
}
