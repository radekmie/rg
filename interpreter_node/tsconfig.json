{
  "compilerOptions": {
    "baseUrl": "src",
    "esModuleInterop": true,
    "importHelpers": true,
    "incremental": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "ES2020"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "noEmit": true,
    "outDir": "lib",
    "rootDir": "src",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "ES2019",
    "tsBuildInfoFile": "./node_modules/.cache/interpreter_node.tsbuildinfo"
  },
  "include": ["src"]
}
