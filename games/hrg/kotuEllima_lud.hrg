
domain Piece = empty | whitePawn | blackPawn | border
domain Player = black | white
domain Score = 50 | 0 | 100
domain Bool = 0 | 1

domain Count = I(X) where X in 0..1250
domain CountOrNan = nan | Count
domain PieceCount = I(X) where X in 0..50

pawnOf : Player -> Piece
pawnOf(white) = whitePawn
pawnOf(black) = blackPawn

opponent : Player -> Player
opponent(white) = black
opponent(black) = white

increment : Count -> CountOrNan
increment(I(X)) = if X < 1250 then I(X+1) else nan

less : PieceCount -> PieceCount -> Bool
less(I(X), I(Y)) = if X < Y then 1 else 0


domain Position = cy0x0 | cy0x1 | cy0x2 | cy0x3 | cy0x4 | cy1x0 | cy1x1 | cy1x2 | cy1x3 | cy1x4 | cy2x0 | cy2x1 | cy2x2 | cy2x3 | cy2x4 | cy3x0 | cy3x1 | cy3x2 | cy3x3 | cy3x4 | cy4x0 | cy4x1 | cy4x2 | cy4x3 | cy4x4 | teastvy1x0 | teastvy1x1 | teastvy1x2 | teastvy2x0 | teastvy2x1 | teastvy2x2 | tnorthvy1x0 | tnorthvy1x1 | tnorthvy1x2 | tnorthvy2x0 | tnorthvy2x1 | tnorthvy2x2 | tsouthvy1x0 | tsouthvy1x1 | tsouthvy1x2 | tsouthvy2x0 | tsouthvy2x1 | tsouthvy2x2 | twestvy1x0 | twestvy1x1 | twestvy1x2 | twestvy2x0 | twestvy2x1 | twestvy2x2 
domain PositionOrNull = null | Position

