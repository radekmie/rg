
domain Piece = empty | whitePawn | blackPawn | border
domain Player = black | white
domain Score = 50 | 0 | 100
domain Bool = 0 | 1

domain Count = I(X) where X in 0..1250
domain CountOrNan = nan | Count
domain PieceCount = I(X) where X in 0..17

pawnOf : Player -> Piece
pawnOf(white) = whitePawn
pawnOf(black) = blackPawn

opponent : Player -> Player
opponent(white) = black
opponent(black) = white

increment : Count -> CountOrNan
increment(I(X)) = if X < 1250 then I(X+1) else nan

less : PieceCount -> PieceCount -> Bool
less(I(X), I(Y)) = if X < Y then 1 else 0


domain Position = cy0x0 | nodeE1 | nodeE2 | nodeW1 | nodeW2 | tnorthvy1x0 | tnorthvy1x1 | tnorthvy1x2 | tnorthvy2x0 | tnorthvy2x1 | tnorthvy2x2 | tsouthvy1x0 | tsouthvy1x1 | tsouthvy1x2 | tsouthvy2x0 | tsouthvy2x1 | tsouthvy2x2 
domain PositionOrNull = null | Position

nextPos : PositionOrNull -> PositionOrNull
nextPos(null) = cy0x0
nextPos(cy0x0) = nodeE1
nextPos(nodeE1) = nodeE2
nextPos(nodeE2) = nodeW1
nextPos(nodeW1) = nodeW2
nextPos(nodeW2) = tnorthvy1x0
nextPos(tnorthvy1x0) = tnorthvy1x1
nextPos(tnorthvy1x1) = tnorthvy1x2
nextPos(tnorthvy1x2) = tnorthvy2x0
nextPos(tnorthvy2x0) = tnorthvy2x1
nextPos(tnorthvy2x1) = tnorthvy2x2
nextPos(tnorthvy2x2) = tsouthvy1x0
nextPos(tsouthvy1x0) = tsouthvy1x1
nextPos(tsouthvy1x1) = tsouthvy1x2
nextPos(tsouthvy1x2) = tsouthvy2x0
nextPos(tsouthvy2x0) = tsouthvy2x1
nextPos(tsouthvy2x1) = tsouthvy2x2
nextPos(tsouthvy2x2) = null

