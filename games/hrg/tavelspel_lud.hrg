domain DirIndex = S(X) where X in 0..3
dirs : DirIndex -> PositionOrNull -> PositionOrNull
dirs(S(0)) = north
dirs(S(1)) = east
dirs(S(2)) = south
dirs(S(3)) = west

board : PositionOrNull -> Piece = {
  :empty;
  null = border;
  cy0x0 = blackPawn;
  cy0x1 = blackPawn;
  cy0x10 = blackPawn;
  cy0x11 = blackPawn;
  cy0x12 = blackPawn;
