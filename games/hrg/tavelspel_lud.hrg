
domain Piece = empty | whitePawn | blackPawn | border
domain Player = black | white
domain Score = 50 | 0 | 100
domain Bool = 0 | 1

domain Count = I(X) where X in 0..1250
domain CountOrNan = nan | Count
domain PieceCount = I(X) where X in 0..53

pawnOf : Player -> Piece
pawnOf(white) = whitePawn
pawnOf(black) = blackPawn

opponent : Player -> Player
opponent(white) = black
opponent(black) = white

increment : Count -> CountOrNan
increment(I(X)) = if X < 1250 then I(X+1) else nan

less : PieceCount -> PieceCount -> Bool
less(I(X), I(Y)) = if X < Y then 1 else 0


domain Position = cy0x0 | cy0x1 | cy0x10 | cy0x11 | cy0x12 | cy0x2 | cy0x3 | cy0x4 | cy0x5 | cy0x6 | cy0x7 | cy0x8 | cy0x9 | cy10x0 | cy10x1 | cy10x10 | cy10x11 | cy10x12 | cy10x2 | cy10x3 | cy10x4 | cy10x5 | cy10x6 | cy10x7 | cy10x8 | cy10x9 | cy11x0 | cy11x1 | cy11x10 | cy11x11 | cy11x12 | cy11x2 | cy11x3 | cy11x4 | cy11x5 | cy11x6 | cy11x7 | cy11x8 | cy11x9 | cy12x0 | cy12x1 | cy12x10 | cy12x11 | cy12x12 | cy12x2 | cy12x3 | cy12x4 | cy12x5 | cy12x6 | cy12x7 | cy12x8 | cy12x9 | cy1x0 | cy1x1 | cy1x10 | cy1x11 | cy1x12 | cy1x2 | cy1x3 | cy1x4 | cy1x5 | cy1x6 | cy1x7 | cy1x8 | cy1x9 | cy2x0 | cy2x1 | cy2x10 | cy2x11 | cy2x12 | cy2x2 | cy2x3 | cy2x4 | cy2x5 | cy2x6 | cy2x7 | cy2x8 | cy2x9 | cy3x0 | cy3x1 | cy3x10 | cy3x11 | cy3x12 | cy3x2 | cy3x3 | cy3x4 | cy3x5 | cy3x6 | cy3x7 | cy3x8 | cy3x9 | cy4x0 | cy4x1 | cy4x10 | cy4x11 | cy4x12 | cy4x2 | cy4x3 | cy4x4 | cy4x5 | cy4x6 | cy4x7 | cy4x8 | cy4x9 | cy5x0 | cy5x1 | cy5x10 | cy5x11 | cy5x12 | cy5x2 | cy5x3 | cy5x4 | cy5x5 | cy5x6 | cy5x7 | cy5x8 | cy5x9 | cy6x0 | cy6x1 | cy6x10 | cy6x11 | cy6x12 | cy6x2 | cy6x3 | cy6x4 | cy6x5 | cy6x6 | cy6x7 | cy6x8 | cy6x9 | cy7x0 | cy7x1 | cy7x10 | cy7x11 | cy7x12 | cy7x2 | cy7x3 | cy7x4 | cy7x5 | cy7x6 | cy7x7 | cy7x8 | cy7x9 | cy8x0 | cy8x1 | cy8x10 | cy8x11 | cy8x12 | cy8x2 | cy8x3 | cy8x4 | cy8x5 | cy8x6 | cy8x7 | cy8x8 | cy8x9 | cy9x0 | cy9x1 | cy9x10 | cy9x11 | cy9x12 | cy9x2 | cy9x3 | cy9x4 | cy9x5 | cy9x6 | cy9x7 | cy9x8 | cy9x9 
