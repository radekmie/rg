#players = red(100), blue(100)
#pieces = b, e, r
#variables = 
#rules = (
  ->red
  (NW* + SE*)
  (SW* + NE*)
  {e}
  ->>
  [r]
  (
      {! ((NW + NE + E + SE + SW + W) {r})* {! NW}}
    + {! ((NW + NE + E + SE + SW + W) {r})* {! SE}}
    + {? ((NW + NE + E + SE + SW + W) {r})* {! NW}} {? ((NW + NE + E + SE + SW + W) {r})* {! SE}} [$ red = 100] ->> {}
  )
  ->blue
  (NW* + SE*)
  (SW* + NE*)
  {e}
  ->>
  [b]
  (
      {! ((NW + NE + E + SE + SW + W) {b})* {! NE}}
    + {! ((NW + NE + E + SE + SW + W) {b})* {! SW}}
    + {? ((NW + NE + E + SE + SW + W) {b})* {! NE}} {? ((NW + NE + E + SE + SW + W) {b})* {! SW}} [$ blue = 100] ->> {}
  )
)*
