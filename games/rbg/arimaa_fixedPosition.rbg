#players = gold(100), silver(100)
#pieces = empty, goldCamel, goldCat, goldDog, goldElephant, goldHorse, goldRabbit, goldRabbitSecond, silverCamel, silverCat, silverDog, silverElephant, silverHorse, silverRabbit, silverRabbitSecond
#variables = changed(1), steps(4), turn(199)
#rules = {$ goldElephant < 1}(
  (
    (left* + right*)
    (up* + down*)
    {!
        {empty} backLayer {empty}
      + {goldElephant} backLayer {goldElephant}
      + {goldCamel} backLayer {goldCamel}
      + {goldHorse} backLayer {goldHorse}
      + {goldDog} backLayer {goldDog}
      + {goldCat} backLayer {goldCat}
      + {goldRabbit} backLayer {goldRabbitSecond}
      + {silverElephant} backLayer {silverElephant}
      + {silverCamel} backLayer {silverCamel}
      + {silverHorse} backLayer {silverHorse}
      + {silverDog} backLayer {silverDog}
      + {silverCat} backLayer {silverCat}
      + {silverRabbit} backLayer {silverRabbitSecond}
    }
    ->>
    (
        {empty} backLayer [empty]
      + {goldElephant} backLayer [goldElephant]
      + {goldCamel} backLayer [goldCamel]
      + {goldHorse} backLayer [goldHorse]
      + {goldDog} backLayer [goldDog]
      + {goldCat} backLayer [goldCat]
      + {goldRabbit} backLayer [goldRabbitSecond]
      + {silverElephant} backLayer [silverElephant]
      + {silverCamel} backLayer [silverCamel]
      + {silverHorse} backLayer [silverHorse]
      + {silverDog} backLayer [silverDog]
      + {silverCat} backLayer [silverCat]
      + {silverRabbit} backLayer [silverRabbitSecond]
    )
    frontLayer
  )*
  {!
    (left* + right*)
    (up* + down*)
    {!
        {empty} backLayer {empty}
      + {goldElephant} backLayer {goldElephant}
      + {goldCamel} backLayer {goldCamel}
      + {goldHorse} backLayer {goldHorse}
      + {goldDog} backLayer {goldDog}
      + {goldCat} backLayer {goldCat}
      + {goldRabbit} backLayer {goldRabbitSecond}
      + {silverElephant} backLayer {silverElephant}
      + {silverCamel} backLayer {silverCamel}
      + {silverHorse} backLayer {silverHorse}
      + {silverDog} backLayer {silverDog}
      + {silverCat} backLayer {silverCat}
      + {silverRabbit} backLayer {silverRabbitSecond}
    }
  }
  (left* + right*)
  (up* + down*)
  {! up + left}
  [$ steps = 4]
  [$ changed = 0]
  ->gold
  (
    {$ steps > 0}
    (left* + right*)
    (up* + down*)
    {goldCamel, goldCat, goldDog, goldElephant, goldHorse, goldRabbit}
    {!
      {!
        (left + right + up + down)
        {goldCamel, goldCat, goldDog, goldElephant, goldHorse, goldRabbit}
      }
      {?
          {goldCamel} (left + right + up + down) {silverElephant}
        + {goldHorse} (left + right + up + down) {silverCamel, silverElephant}
        + {goldDog} (left + right + up + down) {silverCamel, silverElephant, silverHorse}
        + {goldCat} (left + right + up + down) {silverCamel, silverDog, silverElephant, silverHorse}
        + {goldRabbit} (left + right + up + down) {silverCamel, silverCat, silverDog, silverElephant, silverHorse}
      }
    }
    (
        [$ steps = (steps - 1)] (
