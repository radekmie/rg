                            + southEast east east
                            + east east east
                          )
                          {! east + southEast + northEast + southWest}
                        }
                      } (west + northWest)
                  ) {empty}
                + (
                      east {! {empty}} east {empty}
                    + southEast {! {empty}} southEast {empty}
                    + southWest {! {empty}} southWest {empty}
                    + northEast {! {empty}} northEast {empty}
                    + {!
                          {?
                            (
                                southEast southEast southEast
                              + southEast southEast east
                              + southEast east east
                              + east east east
                            )
                            {! east + southEast + northEast + southWest}
                          }
                        + {?
                            (southEast southEast + southEast east + east east)
                            {! east + southEast + northEast + southWest}
                          }
                      } (
                          west {! {empty}} west {empty}
                        + northWest {! {empty}} northWest {empty}
                      )
                  )*
              )
            }
          } ->northWestPlayer (
            northWest + northEast + east + southEast + southWest + west
          )* {northWestPiece} [empty] (
              (
                  east
                + southEast
                + southWest
                + northEast
                + {!
                    {?
                      (
                          southEast southEast southEast
                        + southEast southEast east
                        + southEast east east
                        + east east east
                      )
                      {! east + southEast + northEast + southWest}
                    }
                  } (west + northWest)
              ) {empty}
            + (
                  east {! {empty}} east {empty}
                + southEast {! {empty}} southEast {empty}
                + southWest {! {empty}} southWest {empty}
                + northEast {! {empty}} northEast {empty}
                + {!
                      {?
                        (
                            southEast southEast southEast
                          + southEast southEast east
                          + southEast east east
                          + east east east
                        )
                        {! east + southEast + northEast + southWest}
                      }
                    + {?
                        (southEast southEast + southEast east + east east)
                        {! east + southEast + northEast + southWest}
                      }
                  } (
                      west {! {empty}} west {empty}
                    + northWest {! {empty}} northWest {empty}
                  )
              )*
          ) ->> [northWestPiece] (
              {?
                (
                  northWest + northEast + east + southEast + southWest + west
                )*
                {! east + southEast + northEast + southWest}
                {northWestPiece}
                northWest
                {northWestPiece}
                northWest
                {northWestPiece}
                northWest
                {northWestPiece}
                southWest
                {northWestPiece}
                southWest
                {northWestPiece}
                southWest
                {northWestPiece}
                east
                {northWestPiece}
                east
                {northWestPiece}
                northWest
                {northWestPiece}
              } [$ southPlayer = 0] [$ northPlayer = 0] [$ northWestPlayer = 0] [$ northEastPlayer = 0] [$ southWestPlayer = 0] [$ southEastPlayer = 0] [$ northWestPlayer = 100] ->> {}
            + {!
                (
                  northWest + northEast + east + southEast + southWest + west
                )*
                {! east + southEast + northEast + southWest}
                {northWestPiece}
                northWest
                {northWestPiece}
                northWest
                {northWestPiece}
                northWest
                {northWestPiece}
                southWest
                {northWestPiece}
                southWest
                {northWestPiece}
                southWest
                {northWestPiece}
                east
                {northWestPiece}
                east
                {northWestPiece}
                northWest
                {northWestPiece}
              }
          )
        + {!
            {?
              (
                northWest + northEast + east + southEast + southWest + west
              )*
              (
                  (
                      east
                    + southEast
                    + southWest
                    + northEast
                    + {!
                        {?
                          (
                              southEast southEast southEast
                            + southEast southEast east
                            + southEast east east
                            + east east east
                          )
                          {! east + southEast + northEast + southWest}
                        }
                      } (west + northWest)
                  ) {empty}
                + (
                      east {! {empty}} east {empty}
                    + southEast {! {empty}} southEast {empty}
                    + southWest {! {empty}} southWest {empty}
                    + northEast {! {empty}} northEast {empty}
                    + {!
                          {?
                            (
                                southEast southEast southEast
                              + southEast southEast east
                              + southEast east east
                              + east east east
                            )
                            {! east + southEast + northEast + southWest}
                          }
                        + {?
                            (southEast southEast + southEast east + east east)
                            {! east + southEast + northEast + southWest}
                          }
                      } (
                          west {! {empty}} west {empty}
                        + northWest {! {empty}} northWest {empty}
                      )
                  )*
              )
            }
          } (
            (
              northWest + northEast + east + southEast + southWest + west
            )*
            {northWestPiece}
            [empty]
            ->>
          )* {!
            (
              northWest + northEast + east + southEast + southWest + west
            )*
            {northWestPiece}
          } (
            northWest + northEast + east + southEast + southWest + west
          )* {! northWest + northEast + west + east} [$ northWestPlayer = 0]
      )
    + {$ northWestPiece == 0}
  )
  ->>
  [$ turn = (turn + 1)]
)*
