#players = northPlayer(100), northEastPlayer(100), southEastPlayer(100), southPlayer(100), southWestPlayer(100), northWestPlayer(100)
#pieces = empty, northEastPiece, northPiece, northWestPiece, southEastPiece, southPiece, southWestPiece
#variables = turn(200)
#rules = [$ southPlayer = 50]
[$ northPlayer = 50]
[$ northWestPlayer = 50]
[$ northEastPlayer = 50]
[$ southWestPlayer = 50]
[$ southEastPlayer = 50]
(
  (
      {$ northPiece > 0} (
          {?
            {?
              (
                northWest + northEast + east + southEast + southWest + west
              )*
              (
                  (
                      southEast
                    + southWest
                    + west
                    + east
                    + {!
                        {?
                          (
                              southWest southWest southWest
                            + southWest southWest southEast
                            + southWest southEast southEast
                            + southEast southEast southEast
                          )
                          {! southEast + southWest + east + west}
                        }
                      } (northWest + northEast)
                  ) {empty}
                + (
                      southEast {! {empty}} southEast {empty}
                    + southWest {! {empty}} southWest {empty}
                    + west {! {empty}} west {empty}
                    + east {! {empty}} east {empty}
                    + {!
                          {?
                            (
                                southWest southWest southWest
                              + southWest southWest southEast
                              + southWest southEast southEast
                              + southEast southEast southEast
                            )
                            {! southEast + southWest + east + west}
                          }
                        + {?
                            (
                                southWest southWest
                              + southWest southEast
                              + southEast southEast
                            )
                            {! southEast + southWest + east + west}
                          }
                      } (
                          northWest {! {empty}} northWest {empty}
                        + northEast {! {empty}} northEast {empty}
                      )
                  )*
              )
            }
          } ->northPlayer (
            northWest + northEast + east + southEast + southWest + west
          )* {northPiece} [empty] (
              (
                  southEast
                + southWest
                + west
                + east
                + {!
                    {?
                      (
                          southWest southWest southWest
                        + southWest southWest southEast
                        + southWest southEast southEast
                        + southEast southEast southEast
                      )
                      {! southEast + southWest + east + west}
                    }
                  } (northWest + northEast)
              ) {empty}
            + (
                  southEast {! {empty}} southEast {empty}
                + southWest {! {empty}} southWest {empty}
                + west {! {empty}} west {empty}
                + east {! {empty}} east {empty}
                + {!
                      {?
                        (
                            southWest southWest southWest
                          + southWest southWest southEast
                          + southWest southEast southEast
                          + southEast southEast southEast
                        )
                        {! southEast + southWest + east + west}
                      }
                    + {?
                        (
                            southWest southWest
                          + southWest southEast
                          + southEast southEast
                        )
                        {! southEast + southWest + east + west}
                      }
                  } (
                      northWest {! {empty}} northWest {empty}
                    + northEast {! {empty}} northEast {empty}
                  )
              )*
          ) ->> [northPiece] (
              {?
                (
                  northWest + northEast + east + southEast + southWest + west
                )*
                {! southEast + southWest + east + west}
                {northPiece}
                northEast
                {northPiece}
                northEast
                {northPiece}
                northEast
                {northPiece}
                west
                {northPiece}
                west
                {northPiece}
                west
                {northPiece}
                southEast
                {northPiece}
                southEast
                {northPiece}
                northEast
                {northPiece}
              } [$ southPlayer = 0] [$ northPlayer = 0] [$ northWestPlayer = 0] [$ northEastPlayer = 0] [$ southWestPlayer = 0] [$ southEastPlayer = 0] [$ northPlayer = 100] ->> {}
            + {!
                (
                  northWest + northEast + east + southEast + southWest + west
                )*
