#players = white(100), black(100)
#pieces = b, e, w
#variables = 
#rules = [$ white = 50]
[$ black = 50]
->black
(up* + down*)
(left* + right*)
{e}
->>
[b]
(
  ->white
  (up* + down*)
  (left* + right*)
  {e}
  [w]
  (
      {!
          (up left {w})* down right {w} down right {w} down right {w} down right {w} down right {w}
        + (up {w})* down {w} down {w} down {w} down {w} down {w}
        + (up right {w})* down left {w} down left {w} down left {w} down left {w} down left {w}
        + (left {w})* right {w} right {w} right {w} right {w} right {w}
      }
    + {?
          (up left {w})* down right {w} down right {w} down right {w} down right {w} down right {w}
        + (up {w})* down {w} down {w} down {w} down {w} down {w}
        + (up right {w})* down left {w} down left {w} down left {w} down left {w} down left {w}
        + (left {w})* right {w} right {w} right {w} right {w} right {w}
      } [$ white = 100] [$ black = 0] ->> {}
  )
  (up* + down*)
  (left* + right*)
  {e}
  [w]
  (
      {!
          (up left {w})* down right {w} down right {w} down right {w} down right {w} down right {w}
        + (up {w})* down {w} down {w} down {w} down {w} down {w}
        + (up right {w})* down left {w} down left {w} down left {w} down left {w} down left {w}
        + (left {w})* right {w} right {w} right {w} right {w} right {w}
