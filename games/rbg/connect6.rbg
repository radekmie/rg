        + (up {w})* down {w} down {w} down {w} down {w} down {w}
        + (up right {w})* down left {w} down left {w} down left {w} down left {w} down left {w}
        + (left {w})* right {w} right {w} right {w} right {w} right {w}
      } [$ white = 100] [$ black = 0] ->> {}
  )
  ->black
  (up* + down*)
  (left* + right*)
  {e}
  [b]
  (
      {!
          (up left {b})* down right {b} down right {b} down right {b} down right {b} down right {b}
        + (up {b})* down {b} down {b} down {b} down {b} down {b}
        + (up right {b})* down left {b} down left {b} down left {b} down left {b} down left {b}
