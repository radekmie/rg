
domain Piece = empty | whitePawn | blackPawn | border
domain Player = black | white
domain Score = 50 | 0 | 100
domain Bool = 0 | 1

domain Count = I(X) where X in 0..1250
domain CountOrNan = nan | Count
domain PieceCount = I(X) where X in 0..49

pawnOf : Player -> Piece
pawnOf(white) = whitePawn
pawnOf(black) = blackPawn

opponent : Player -> Player
opponent(white) = black
opponent(black) = white

increment : Count -> CountOrNan
increment(I(X)) = if X < 1250 then I(X+1) else nan

less : PieceCount -> PieceCount -> Bool
less(I(X), I(Y)) = if X < Y then 1 else 0


domain Position = cy0x0 | cy0x1 | cy0x2 | cy0x3 | cy0x4 | cy0x5 | cy0x6 | cy0x7 | cy0x8 | cy1x0 | cy1x1 | cy1x2 | cy1x3 | cy1x4 | cy1x5 | cy1x6 | cy1x7 | cy1x8 | cy2x0 | cy2x1 | cy2x2 | cy2x3 | cy2x4 | cy2x5 | cy2x6 | cy2x7 | cy2x8 | cy3x0 | cy3x1 | cy3x2 | cy3x3 | cy3x4 | cy3x5 | cy3x6 | cy3x7 | cy3x8 | cy4x0 | cy4x1 | cy4x2 | cy4x3 | cy4x4 | cy4x5 | cy4x6 | cy4x7 | cy4x8 | cy5x0 | cy5x1 | cy5x2 | cy5x3 | cy5x4 | cy5x5 | cy5x6 | cy5x7 | cy5x8 | cy6x0 | cy6x1 | cy6x2 | cy6x3 | cy6x4 | cy6x5 | cy6x6 | cy6x7 | cy6x8 | cy7x0 | cy7x1 | cy7x2 | cy7x3 | cy7x4 | cy7x5 | cy7x6 | cy7x7 | cy7x8 | cy8x0 | cy8x1 | cy8x2 | cy8x3 | cy8x4 | cy8x5 | cy8x6 | cy8x7 | cy8x8 
